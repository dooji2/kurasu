{
	"schemaVersion": 1,
	"id": "kurasu",
	"version": "${version}",
	"name": "Kurasu",
	"description": "Adds lockers (you can place stuff in), classroom furniture, and more!",
	"authors": [
		"dooji"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/kurasu",
		"sources": "https://github.com/dooji2/kurasu"
	},
	"license": "Custom License",
	"icon": "assets/kurasu/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.dooji.kurasu.Kurasu"
		],
		"client": [
			"com.dooji.kurasu.client.KurasuClient"
		]
	},
	"mixins": [
		"kurasu.mixins.json",
